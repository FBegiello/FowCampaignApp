    {
        public double Width { get; set; }
        public double Height { get; set; }
    }


    private async Task OpenExcelEditor(UnitAppDto unitApp)
    {
        _editingUnitApp = unitApp;
        _activeExcelGrid = new List<List<string>>();

        if (!string.IsNullOrWhiteSpace(unitApp.ExcelDatabase64))
        {
            try
            {
                _originalExcelBytes = Convert.FromBase64String(unitApp.ExcelDatabase64);
                using var stream = new MemoryStream(_originalExcelBytes);
                using var workbook = new XLWorkbook(stream);
                var worksheet = workbook.Worksheets.First();

                var rowsTotal = worksheet.LastRowUsed().RowNumber();
                var colsTotal = worksheet.LastColumnUsed().ColumnNumber();

                for (var r = 1; r <= rowsTotal; r++)
                {
                    var rowList = new List<string>();
                    for (var c = 1; c <= colsTotal; c++)
                    {
                        var cellValue = worksheet.Cell(r, c).GetValue<string>();
                        rowList.Add(cellValue);
                    }

                    _activeExcelGrid.Add(rowList);
                }
            }
            catch (Exception e)
            {
                Console.WriteLine($"Erro reading excel file: {e.Message}");
                GenerateBlankTemplate();
            }
        }
        else
        {
            GenerateBlankTemplate();
        }
    }


    private async Task GenerateBlankTemplate()
    {
        _originalExcelBytes = null;
        _activeExcelGrid = new List<List<string>>();
    }

    private void AddExcelRow()
    {
        if (_activeExcelGrid != null && _activeExcelGrid.Any())
        {
            var colCount = _activeExcelGrid.First().Count;
            var newRow = new List<string>(new string[colCount]);
            for (var i = 0; i < colCount; i++) newRow[i] = "";
            _activeExcelGrid.Add(newRow);
        }
    }

    private void AddExcelColumn()
    {
        if (_activeExcelGrid != null)
        {
            foreach (var row in _activeExcelGrid)
            {
                row.Add("");
            }
        }
    }

    private void SaveExcelData()
    {
        if (_editingUnitApp != null && _activeExcelGrid != null)
        {
            XLWorkbook workbook;

            if (_originalExcelBytes != null)
            {
                var stream = new MemoryStream(_originalExcelBytes);
                workbook = new XLWorkbook(stream);
            }
            else
            {
                workbook = new XLWorkbook();
                workbook.Worksheets.Add("Unit Intel");
            }

            var worksheet = workbook.Worksheet(1);

            for (var r = 0; r < _activeExcelGrid.Count; r++)
            {
                for (var c = 0; c < _activeExcelGrid[r].Count; c++)
                {
                    worksheet.Cell(r + 1, c + 1).Value = _activeExcelGrid[r][c] ?? "";
                }
            }

            using var outStream = new MemoryStream();
            workbook.SaveAs(outStream);
            _editingUnitApp.ExcelDatabase64 = Convert.ToBase64String(outStream.ToArray());

            CloseExcelEditor();
        }
    }

    private void CloseExcelEditor()
    {
        _editingUnitApp = null;
        _activeExcelGrid = null;
        _originalExcelBytes = null;
    }

    private void ToggleDeploymentMode()
    {
        if (_turnPhase == TurnPhase.Deployment)
        {
            _turnPhase = TurnPhase.Planning;
            _selectedDeployDefId = string.Empty;
        }
        else
        {
            _turnPhase = TurnPhase.Deployment;
        }
    }

    private void CloseRosterModal()
    {
        _showRosterModal = false;
        CloseExcelEditor();
    }

    private async Task HandleDeployedUnitExcel(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (!file.Name.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        try
        {
            var maxFileSize = 1024 * 1024 * 5;
            using var stream = new MemoryStream();
            await file.OpenReadStream(maxFileSize).CopyToAsync(stream);

            _pendingDeployExcelBase64 = Convert.ToBase64String(stream.ToArray());
            _pendingDeployExcelName = file.Name;
        }
        catch (Exception exception)
        {
            Console.WriteLine($"Error reading excel file: {exception.Message}");
        }
    }


