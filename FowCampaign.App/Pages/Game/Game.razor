@page "/game/{Id:int}"
@using System.Globalization
@using System.Text.Json
@using ClosedXML.Excel
@using FowCampaign.App.DTO
@using FowCampaign.App.Shared

@attribute [Authorize]

@layout HomeLayout


@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager NavigationManager




<PaperSheet @ref="_paper">

    @if (_isLoading)
    {
        <div style="text-align:center; padding-top: 100px; font-family: 'Courier New';">
            <h3>DECRYPTING BATTLE PLANS...</h3>
            <p>Loading Campaign #@Id</p>
        </div>
    }
    else if (_loadError)
    {
        <div style="color:red; text-align:center; padding-top: 50px;">
            <h3>MISSION ABORTED</h3>
            <p>Could not load campaign data. Server may be offline.</p>
            <button class="btn-leave" style="width:auto; padding: 10px 20px;"
                    @onclick='() => NavigationManager.NavigateTo("/home")'>RETURN TO BASE
            </button>
        </div>
    }
    else
    {
        @if (_stateApp != null)
        {
            <div class="turn-banner"
                 style="background-color: @(_ = GetFactionColor(_stateApp.CurrentTurnFaction).Result);">
                TURN @(_stateApp.TurnNumber): @(_stateApp.CurrentTurnFaction.ToUpper())
            </div>
        }

        <div class="game-container">

            <div class="map-panel">

                <div class="map-sticky-header">
                    <span>OP: @_gameDataApp.Name</span>
                    <span>Playing As: <span style="color:yellow;">@_gameDataApp.MyFactionName</span></span>
                </div>

                <div class="canvas-container" style="position: relative; width: fit-content; height: fit-content;"
                     @onmousemove="HandleWrapperMouseMove"
                     @onmouseup="HandleWrapperMouseUp">

                    <canvas id="gameCanvas" class="game-canvas" @onclick="HandleMapClick"></canvas>
                    @if (_isProcessingMap)
                    {
                        <div class="map-overlay-blocker">
                            <div class="processing-panel">
                                <div class="processing-text">UPDATING TACTICAL MAP...</div>
                                <div class="progress-track">
                                    <div class="progress-bar-moving"></div>
                                </div>
                            </div>
                        </div>
                    }
                    @if (_stateApp != null)
                    {
                        @foreach (var unit in _stateApp.Units)
                        {
                            var def = _stateApp.UnitDefinitions.FirstOrDefault(d => d.Id == unit.DefinitionId);

                            var isMyUnit = unit.FactionName == _gameDataApp.MyFactionName;
                            var isMyTurn = _stateApp.CurrentTurnFaction == _gameDataApp.MyFactionName;
                            var canDrag = isMyUnit && isMyTurn;

                            var dragClass = canDrag ? "unit-draggable" : "unit-locked";
                            var pointerClass = _draggingUnitApp != null ? "pointer-events-none" : "";
                            var leftPercent = unit.X / _mapRealWidth * 100.0;
                            var topPercent = unit.Y / _mapRealHeight * 100.0;

                            var factionColor = GetFactionColor(unit.FactionName);
                            var positionStyle = $"left: {leftPercent.ToString("F2", CultureInfo.InvariantCulture)}%; top: {topPercent.ToString("F2", CultureInfo.InvariantCulture)}%; border: 2px solid {factionColor}; box-shadow: 0 0 5px {factionColor};";


                            if (def != null)
                            {
                                <div class="map-unit @dragClass @pointerClass"
                                     style="@positionStyle"
                                     @onmousedown="() => StartDrag(unit)"
                                     @onmousedown:stopPropagation="true">

                                    <img src="@def.ImageBase64" style="width:100%; height:100%; object-fit:contain;"
                                         title="@def.Name"/>
                                </div>
                            }
                        }
                    }

                    }
                </div>
            </div>

            <div class="intel-sidebar">

                <div class="sidebar-section">
                    <h4 class="section-header">COMMAND</h4>

                    @if (_stateApp?.CurrentTurnFaction == _gameDataApp?.MyFactionName)
                    {
                        <button class="btn-full btn-open-roster" @onclick="() => _showRosterModal = true">
                            OPEN UNIT ROSTER
                        </button>

                        @if (_turnPhase == TurnPhase.Planning || _turnPhase == TurnPhase.Deployment)
                        {
                            <div class="status-box status-active mb-5">
                                <strong>STATUS:</strong> Awaiting Orders
                            </div>

                            <button class="btn-full mb-5"
                                    style="background-color: @(_turnPhase == TurnPhase.Deployment ? "#8b0000" : "#444"); color: white;"
                                    @onclick="ToggleDeploymentMode">
                                @(_turnPhase == TurnPhase.Deployment ? "CANCEL DEPLOYMENT" : "RECRUIT NEW UNIT")
                            </button>

                            @if (_turnPhase == TurnPhase.Deployment)
                            {
                                <div class="deployment-panel">
                                    <select @bind="_selectedDeployDefId" class="tactical-input-white mb-10">
                                        <option value="">-- Select Unit Type --</option>
                                        @foreach (var def in _stateApp.UnitDefinitions)
                                        {
                                            <option value="@def.Id">@def.Name</option>
                                        }
                                    </select>

                                    <label class="btn-full btn-attach-excel">
                                        ATTACH EXCEL (OPT)
                                        <InputFile OnChange="@HandleDeployedUnitExcel" style="display: none;"
                                                   accept=".xlsx"/>
                                    </label>

                                    @if (!string.IsNullOrEmpty(_pendingDeployExcelName))
                                    {
                                        <span class="attached-file-label">Attached: @_pendingDeployExcelName</span>
                                    }

                                    <span class="deployment-instruction">CLICK ON THE MAP TO DEPLOY</span>
                                </div>
                            }

                            @if (_turnPhase != TurnPhase.Deployment)
                            {
                                <button class="btn-full btn-confirm"
                                        @onclick="() => { _turnPhase = TurnPhase.Capture; StateHasChanged(); }">
                                    CONFIRM MOVES
                                </button>
                            }
                        }
                        else if (_turnPhase == TurnPhase.Capture)
                        {
                            <div class="status-box status-active"><strong>STATUS:</strong> Capture Phase</div>
                            <button class="btn-full btn-confirm"
                                    @onclick="() => { _turnPhase = TurnPhase.Planning; StateHasChanged(); }">BACK
                            </button>
                            <button class="btn-full btn-capture" @onclick="SubmitTurn">CONFIRM CAPTURE & SAVE</button>
                        }
                    }
                    else
                    {
                        <div class="status-box status-waiting"><strong>STATUS:</strong> Enemy Acting</div>
                        <button class="btn-full btn-wait" disabled>WAITING...</button>
                    }
                </div>

                @if (_stateApp?.CurrentTurnFaction == _gameDataApp?.MyFactionName
                     && _turnPhase == TurnPhase.Planning
                     && _battleAvailable)
                {
                    <div class="sidebar-section">
                        <div class="status-box status-battle">
                            <strong>⚔ CONTACT:</strong> @_battleZoneName
                        </div>
                        <button class="btn-full btn-battle" @onclick="openBattlePanel">
                            INITIATE BATTLE
                        </button>
                    </div>
                }

                @if (_showBattlePanel && _battleZone != null)
                {
                    <div class="sidebar-section battle-panel">
                        <h4 class="section-header">⚔ BATTLE — @(_battleZoneName.ToUpper())</h4>

                        @foreach (var faction in _battleUnits.Select(u => u.FactionName).Distinct())
                        {
                            <div class="battle-faction-row vintage-counter-box">
                                <div class="battle-faction-label faction-stamp"
                                     style="border-color: @GetFactionColor(faction); color: @GetFactionColor(faction);">
                                    @faction.ToUpper()
                                </div>

                                <div class="battle-points-row counter-grid">
                                    <div class="counter-field">
                                        <label class="battle-points-label typewriter-label">MAJOR VP</label>
                                        <div class="mechanical-slot">
                                            <div class="slot-shading"></div>

                                            <input type="number" class="hidden-interactive-input" min="0"
                                                   value="@_majorPoints[faction]"
                                                   @oninput="e => _majorPoints[faction] = int.TryParse(e.Value?.ToString(), out var v) ? v : 0"/>

                                            <div class="rolling-number" @key="_majorPoints[faction]">
                                                @_majorPoints[faction]
                                            </div>
                                        </div>
                                    </div>

                                    <div class="counter-field">
                                        <label class="battle-points-label typewriter-label">MINOR VP</label>
                                        <div class="mechanical-slot">
                                            <div class="slot-shading"></div>

                                            <input type="number" class="hidden-interactive-input" min="0"
                                                   value="@_minorPoints[faction]"
                                                   @oninput="e => _minorPoints[faction] = int.TryParse(e.Value?.ToString(), out var v) ? v : 0"/>

                                            <div class="rolling-number" @key="_minorPoints[faction]">
                                                @_minorPoints[faction]
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }

                        <div class="battle-intel-section">
                            <label class="battle-points-label typewriter-label"
                                   style="margin-bottom: 10px; display: block;">TACTICAL INTEL (EXCEL)</label>

                            @if (_editingUnitApp == null)
                            {
                                <div class="intel-roster" style="display: flex; flex-direction: column; gap: 5px;">
                                    @foreach (var u in _battleUnits)
                                    {
                                        var def = _stateApp.UnitDefinitions.FirstOrDefault(d => d.Id == u.DefinitionId);
                                        <button class="btn-full"
                                                style="background-color: #2e7d32; color: white; text-align: left; padding: 10px;"
                                                @onclick="() => OpenExcelEditor(u)">
                                            📄 EDIT: [@u.FactionName] @(def?.Name ?? "Unknown Unit")
                                        </button>
                                    }
                                </div>
                            }
                            else if (_activeExcelGrid != null)
                            {
                                <div class="excel-editor-panel"
                                     style="background: #1e1e1e; padding: 10px; border: 1px solid #444; margin-top: 10px;">
                                    <div
                                        style="color: #4caf50; font-family: 'Courier New'; margin-bottom: 10px; font-weight: bold;">
                                        EDITING: @_stateApp.UnitDefinitions.FirstOrDefault(d => d.Id == _editingUnitApp.DefinitionId)?.Name
                                    </div>

                                    <div style="overflow-x: auto; margin-bottom: 10px;">
                                        <table style="width: 100%; border-collapse: collapse;">
                                            <tbody>
                                            @for (var i = 0; i < _activeExcelGrid.Count; i++)
                                            {
                                                var rowIndex = i;
                                                <tr>
                                                    @for (var j = 0; j < _activeExcelGrid[rowIndex].Count; j++)
                                                    {
                                                        var colIndex = j;
                                                        <td style="border: 1px solid #555; padding: 0;">
                                                            <input type="text"
                                                                   @bind="_activeExcelGrid[rowIndex][colIndex]"
                                                                   style="width: 100%; box-sizing: border-box; background: #333; color: #fff; border: none; font-family: 'Courier New'; padding: 6px;"/>
                                                        </td>
                                                    }
                                                </tr>
                                            }
                                            </tbody>
                                        </table>
                                    </div>

                                    <div style="display: flex; gap: 5px; margin-bottom: 15px;">
                                        <button class="btn-full"
                                                style="padding: 5px; font-size: 0.8rem; background-color: #444;"
                                                @onclick="AddExcelRow">+ ADD ROW
                                        </button>
                                        <button class="btn-full"
                                                style="padding: 5px; font-size: 0.8rem; background-color: #444;"
                                                @onclick="AddExcelColumn">+ ADD COLUMN
                                        </button>
                                    </div>

                                    <div style="display: flex; gap: 10px;">
                                        <button class="btn-full btn-confirm" @onclick="SaveExcelData">✔ SAVE INTEL
                                        </button>
                                        <button class="btn-full btn-abort" @onclick="CloseExcelEditor">CANCEL</button>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="battle-actions">
                            <button class="btn-full btn-abort" @onclick="() => _showBattlePanel = false">
                                CANCEL
                            </button>
                            <button class="btn-full btn-confirm" @onclick="ConfirmBattleResults">
                                ✔ CONFIRM BATTLE
                            </button>
                        </div>
                    </div>
                }


                <div class="intel-table-container">
                    <h4 class="intel-header">TERRITORY CONTROL</h4>

                    <table class="intel-table">
                        <thead>
                        <tr>
                            <td>REGION</td>
                            <td style="text-align: right;">OWNER</td>
                        </tr>
                        </thead>
                        <tbody>
                        @if (_stateApp != null && _stateApp.Zones != null)
                        {
                            @foreach (var zone in _stateApp.Zones.OrderBy(z => z.Name))
                            {
                                <tr class="intel-row">
                                    <td style="font-weight: bold; color: #333;">
                                        @(string.IsNullOrWhiteSpace(zone.Name) ? "Unknown Sector" : zone.Name)
                                    </td>
                                    <td style="text-align: right;">
                                        <span class="faction-badge"
                                              style="background-color: @GetFactionColor(zone.FactionName);">
                                            @zone.FactionName.ToUpper()
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>

                <div class="sidebar-section">
                    <button class="btn-full btn-abort" @onclick='() => NavigationManager.NavigateTo("/home")'>
                        LEAVE WAR ROOM
                    </button>
                </div>

            </div>
        </div>
    }
</PaperSheet>

@if (_showRosterModal)
{
    <div class="roster-modal-overlay">
        <div class="roster-modal-content">

            <div class="roster-modal-header">
                <h2 class="roster-modal-title">
                    <span style="color: @GetFactionColor(_gameDataApp.MyFactionName).Result;">
                        @_gameDataApp.MyFactionName.ToUpper()
                    </span> TACTICAL ROSTER
                </h2>
                <button class="btn-close-modal" @onclick="CloseRosterModal">
                    CLOSE [X]
                </button>
            </div>

            @if (_editingUnitApp == null)
            {
                <table class="roster-table">
                    <thead>
                    <tr>
                        <th>UNIT TYPE</th>
                        <th>INTEL ATTACHMENT</th>
                        <th>MAP LOCATION</th>
                        <th class="text-right">ACTION</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var u in _stateApp.Units.Where(x => x.FactionName == _gameDataApp.MyFactionName))
                    {
                        var def = _stateApp.UnitDefinitions.FirstOrDefault(d => d.Id == u.DefinitionId);
                        <tr class="roster-table-row">
                            <td>
                                @if (def != null)
                                {
                                    <img src="@def.ImageBase64" class="roster-unit-icon"/>
                                }
                                <strong>@(def?.Name ?? "Unknown Unit")</strong>
                            </td>
                            <td class="text-muted">
                                @(string.IsNullOrEmpty(u.ExcelDatabase64) ? "[ No File ]" : string.IsNullOrEmpty(u.ExcelFileName) ? "[ Custom Edited Grid ]" : u.ExcelFileName)
                            </td>
                            <td class="text-dim">
                                X: @((int)u.X), Y: @((int)u.Y)
                            </td>
                            <td class="text-right">
                                <button class="btn-edit-excel" @onclick="() => OpenExcelEditor(u)">
                                    EDIT EXCEL
                                </button>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
            else if (_activeExcelGrid != null)
            {
                <div class="excel-editor-container">
                    <h3 class="excel-editor-title">
                        EDITING: @_stateApp.UnitDefinitions.FirstOrDefault(d => d.Id == _editingUnitApp.DefinitionId)?.Name
                    </h3>

                    <div class="excel-table-wrapper">
                        <table class="excel-grid-table">
                            <tbody>
                            @for (var i = 0; i < _activeExcelGrid.Count; i++)
                            {
                                var rowIndex = i;
                                <tr>
                                    @for (var j = 0; j < _activeExcelGrid[rowIndex].Count; j++)
                                    {
                                        var colIndex = j;
                                        <td>
                                            <input type="text" class="excel-cell-input"
                                                   @bind="_activeExcelGrid[rowIndex][colIndex]"/>
                                        </td>
                                    }
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>

                    <div class="excel-editor-controls">
                        <button class="btn-excel-tool" @onclick="AddExcelRow">ADD ROW</button>
                        <button class="btn-excel-tool" @onclick="AddExcelColumn">ADD COLUMN</button>
                    </div>

                    <div class="excel-editor-actions">
                        <button class="btn-save-roster" @onclick="SaveExcelData">SAVE TO ROSTER</button>
                        <button class="btn-cancel-roster" @onclick="CloseExcelEditor">CANCEL</button>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private PaperSheet _paper;
    private LoadGameDataAppDto _gameDataApp;
    private GameStateAppDto _stateApp;
    private UnitAppDto _draggingUnitApp;
    private bool _isProcessingMap;
    private bool _battleAvailable;
    private bool _showBattlePanel;
    private string _battleZoneName;
    private ZoneSeedAppDto _battleZone;
    private List<UnitAppDto> _battleUnits = [];
    private double _mapRealWidth = 1;
    private double _mapRealHeight = 1;
    private double _dragScaleFactor = 1.0;

    private readonly Dictionary<string, int> _majorPoints = new();
    private readonly Dictionary<string, int> _minorPoints = new();

    private string _unitToRemoveId;

    private static string UnitUiKey(UnitAppDto u)
    {
        return $"{u.FactionName}|{u.DefinitionId}|{u.X}|{u.Y}";
    }


    private enum TurnPhase
    {
        Planning,
        Capture,
        Deployment,
        Processing
    }

    private TurnPhase _turnPhase = TurnPhase.Planning;
    private bool _isLoading = true;
    private bool _loadError;
    private bool _mapRendered;

    private UnitAppDto _editingUnitApp;
    private List<List<string>> _activeExcelGrid = new();
    private byte[] _originalExcelBytes;
    private bool _showRosterModal;
    private string _selectedDeployDefId = string.Empty;
    private string _pendingDeployExcelName = string.Empty;
    private string _pendingDeployExcelBase64 = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _gameDataApp = await Http.GetFromJsonAsync<LoadGameDataAppDto>($"api/Campaign/{Id}");

            if (!string.IsNullOrEmpty(_gameDataApp.GameStateJson))
            {
                _stateApp = JsonSerializer.Deserialize<GameStateAppDto>(_gameDataApp.GameStateJson);

                if (string.IsNullOrEmpty(_stateApp.CurrentTurnFaction))
                {
                    _stateApp.CurrentTurnFaction = _stateApp.Factions.FirstOrDefault()?.Name ?? "Axis";
                    _stateApp.TurnNumber = 1;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading game: {ex.Message}");
            _loadError = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task<string> GetFactionColor(string factionName)
    {
        return _stateApp?.Factions.FirstOrDefault(f => f.Name == factionName)?.Color ?? "#000000";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_isLoading && !_loadError && !_mapRendered && _gameDataApp != null)
        {
            _mapRendered = true;

            try
            {
                var dims = await JS.InvokeAsync<MapDimensions>("mapTools.initMap", "gameCanvas", _gameDataApp.MapImageBase64);

                if (dims.Width > 0)
                {
                    _mapRealWidth = dims.Width;
                    _mapRealHeight = dims.Height;
                    StateHasChanged();
                }

                if (_stateApp != null)
                {
                    foreach (var zone in _stateApp.Zones)
                    {
                        var f = _stateApp.Factions.FirstOrDefault(fn => fn.Name == zone.FactionName);
                        if (f != null) await JS.InvokeVoidAsync("mapTools.floodFillRaw", zone.X, zone.Y, f.Color);
                    }
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine("Map Render Failed: " + ex.Message);
            }
        }
    }


    private async Task StartDrag(UnitAppDto unitApp)
    {
        if (_turnPhase != TurnPhase.Planning)
        {
            return;
        }

        if (unitApp.FactionName == _gameDataApp.MyFactionName &&
            _stateApp.CurrentTurnFaction == _gameDataApp.MyFactionName)
        {
            _draggingUnitApp = unitApp;

            var visualDims = await JS.InvokeAsync<MapDimensions>("mapTools.getClientDimensions", "gameCanvas");

            if (visualDims.Width > 0)
            {
                _dragScaleFactor = _mapRealWidth / visualDims.Width;
            }
        }
    }

    private async Task HandleWrapperMouseMove(MouseEventArgs e)
    {
        if (_draggingUnitApp != null)
        {
            _draggingUnitApp.X = e.OffsetX * _dragScaleFactor;
            _draggingUnitApp.Y = e.OffsetY * _dragScaleFactor;
        }
    }

    private async Task HandleWrapperMouseUp()
    {
        _draggingUnitApp = null;
        await RecalculateBattleAvailability();
    }

    private async Task SubmitTurn()
    {
        var endTurnReqestDto = new EndTurnRequestAppDto
        {
            Units = _stateApp.Units,
            Zones = _stateApp.Zones
        };
        var response = await Http.PostAsJsonAsync($"api/Campaign/{Id}/turn", endTurnReqestDto);
        if (response.IsSuccessStatusCode)
        {
            NavigationManager.NavigateTo(NavigationManager.Uri, true);
        }
    }

    private async Task HandleMapClick(MouseEventArgs e)
    {
        if (_stateApp == null || _gameDataApp == null || _isProcessingMap) return;

        if (_stateApp.CurrentTurnFaction != _gameDataApp.MyFactionName)
        {
            return;
        }

        if (_turnPhase == TurnPhase.Deployment)
        {
            if (string.IsNullOrWhiteSpace(_selectedDeployDefId))
            {
                return;
            }

            var realCoords = await JS.InvokeAsync<CampaignCreator.PaintCoord>(
                "mapTools.getSize",
                e.OffsetX,
                e.OffsetY
            );

            if (realCoords is not null)
            {
                var newUnit = new UnitAppDto
                {
                    Id = Guid.NewGuid().ToString(),
                    DefinitionId = _selectedDeployDefId,
                    FactionName = _gameDataApp.MyFactionName,
                    X = realCoords.X,
                    Y = realCoords.Y,
                    ExcelFileName = _pendingDeployExcelName,
                    ExcelDatabase64 = _pendingDeployExcelBase64
                };

                _stateApp.Units.Add(newUnit);

                _pendingDeployExcelBase64 = null;
                _pendingDeployExcelName = null;
                StateHasChanged();
            }

            return;
        }

        if (_turnPhase != TurnPhase.Capture) return;
        _isProcessingMap = true;
        StateHasChanged();
        _turnPhase = TurnPhase.Processing;

        await Task.Delay(50);

        try
        {
            var realCoords = await JS.InvokeAsync<CampaignCreator.PaintCoord>(
                "mapTools.getSize",
                e.OffsetX,
                e.OffsetY
            );

            if (realCoords == null)
            {
                return;
            }

            ZoneSeedAppDto currentRegion = null;
            var distanceMin = double.MaxValue;

            foreach (var region in _stateApp.Zones)
            {
                var distanceX = realCoords.X - region.X;
                var distanceY = realCoords.Y - region.Y;

                var distance = distanceX * distanceX + distanceY * distanceY;

                if (distanceMin > distance)
                {
                    distanceMin = distance;
                    currentRegion = region;
                }
            }

            double maxDistanceSquared = 250 * 250;

            if (currentRegion != null && distanceMin < maxDistanceSquared)
            {
                Console.WriteLine($"DEBUG: Trafiono region {currentRegion.Name}. Rozpoczynam kolorowanie...");

                currentRegion.FactionName = _gameDataApp.MyFactionName;
                var myFactionColor = GetFactionColor(_gameDataApp.MyFactionName);

                await JS.InvokeVoidAsync("mapTools.floodFillRaw", (int)currentRegion.X, (int)currentRegion.Y, myFactionColor);

                _stateApp.Zones = _stateApp.Zones.Select(z =>
                    z.X == currentRegion.X && z.Y == currentRegion.Y
                        ? new ZoneSeedAppDto { X = z.X, Y = z.Y, FactionName = currentRegion.FactionName, Name = z.Name }
                        : z
                ).ToList();
            }
        }

        catch (Exception ex)
        {
            Console.WriteLine($"Coloring Error: {ex.Message}");
        }
        finally
        {
            _isProcessingMap = false;
            _turnPhase = TurnPhase.Capture;
            StateHasChanged();
        }
    }

    private async Task RecalculateBattleAvailability()
    {
        _battleAvailable = false;
        _battleZone = null;
        _battleZoneName = string.Empty;
        _battleUnits.Clear();

        if (_stateApp == null)
        {
            return;
        }

        foreach (var zone in _stateApp.Zones)
        {
            var unitsInZone = _stateApp.Units.Where(u =>
                {
                    var dx = u.X - zone.X;
                    var dy = u.Y - zone.Y;
                    return dx * dx + dy * dy < 80 * 80;
                })
                .ToList();

            var factions = unitsInZone.Select(u => u.FactionName)
                .Where(f => !string.IsNullOrWhiteSpace(f))
                .Distinct()
                .ToList();

            if (factions.Count >= 2)
            {
                _battleAvailable = true;
                _battleZone = zone;
                _battleZoneName = string.IsNullOrWhiteSpace(zone.Name) ? "Unknown Sector" : zone.Name;
                _battleUnits = unitsInZone;

                _majorPoints.Clear();
                _minorPoints.Clear();

                foreach (var faction in factions)
                {
                    _majorPoints[faction] = 0;
                    _minorPoints[faction] = 0;
                }

                return;
            }
        }
    }

    private async Task openBattlePanel()
    {
        if (_battleAvailable)
        {
            _showBattlePanel = true;
        }
    }

    private async Task RemoveSelectedUnitIfAny()
    {
        if (string.IsNullOrWhiteSpace(_unitToRemoveId) || _stateApp == null)
        {
            return;
        }

        var target = _stateApp.Units.FirstOrDefault(u => UnitUiKey(u) == _unitToRemoveId);
        if (target != null)
        {
            _stateApp.Units.Remove(target);
        }

        _unitToRemoveId = null;
    }

    private async Task ConfirmBattleResults()
    {
        if (_stateApp == null || _battleZone == null)
        {
            return;
        }

        var updatedFiles = new Dictionary<string, string>();

        foreach (var u in _battleUnits)
        {
            if (!string.IsNullOrWhiteSpace(u.ExcelDatabase64))
            {
                updatedFiles[u.Id] = u.ExcelDatabase64;
            }
        }


        var dto = new BattleResultAppDto
        {
            ZoneName = _battleZoneName,
            TurnNumber = _stateApp.TurnNumber,
            MajorPoints = _majorPoints,
            MinorPoints = _minorPoints,
            UpdatedUnitFiles = updatedFiles
        };

        var response = await Http.PostAsJsonAsync($"api/Campaign/{Id}/battle", dto);
        if (!response.IsSuccessStatusCode)
            return;
        _showBattlePanel = false;
        await RecalculateBattleAvailability();
        StateHasChanged();
    }

